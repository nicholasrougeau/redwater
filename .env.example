# Supabase — website_leads table (insert-only anon policy)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ConvertKit — newsletter form
VITE_CONVERTKIT_FORM_ID=0000000
VITE_CONVERTKIT_API_URL=https://api.convertkit.com/v3/forms

# Cal.com — inline embed (format: username/event-slug)
VITE_CAL_USERNAME=redwaterrev/strategy-call

# Cloudflare Turnstile — bot protection on forms
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Plausible analytics domain
VITE_PLAUSIBLE_DOMAIN=redwaterrev.com
